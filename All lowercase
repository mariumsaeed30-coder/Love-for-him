<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A World for You ❤️</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 25%, #f8e8ff 50%, #f3e8ff 75%, #fdf2f8 100%);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            color: #4a4a4a;
            line-height: 1.7;
            overflow-x: hidden;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Welcome Page */
        .welcome {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            position: relative;
            background: radial-gradient(circle at center, rgba(255,182,193,0.3) 0%, transparent 70%);
        }

        .welcome h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 8vw, 5rem);
            color: #8b1a4e;
            margin-bottom: 2rem;
            opacity: 0;
            animation: fadeInUp 1.5s ease forwards;
        }

        .welcome p {
            font-size: clamp(1.2rem, 4vw, 1.8rem);
            color: #6b4e71;
            margin-bottom: 3rem;
            max-width: 600px;
            opacity: 0;
            animation: fadeInUp 1.5s ease 0.3s forwards;
        }

        .enter-btn {
            background: linear-gradient(45deg, #ff69b4, #ff1493);
            color: white;
            border: none;
            padding: 1rem 2.5rem;
            font-size: 1.2rem;
            font-weight: 600;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(255,105,180,0.4);
            opacity: 0;
            animation: fadeInUp 1.5s ease 0.6s forwards;
        }

        .enter-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(255,105,180,0.6);
        }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Hearts Animation */
        .hearts {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .heart {
            position: absolute;
            color: #ff69b4;
            font-size: 1.5rem;
            animation: float 6s infinite linear;
        }

        @keyframes float {
            0% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 1;
            }
            100% {
                transform: translateY(-100px) rotate(360deg);
                opacity: 0;
            }
        }

        /* Navigation */
        .nav {
            position: fixed;
            top: 2rem;
            right: 2rem;
            z-index: 1000;
        }

        .nav a {
            display: block;
            color: #8b1a4e;
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 0.5rem;
            opacity: 0.7;
            transition: all 0.3s ease;
        }

        .nav a:hover {
            opacity: 1;
            transform: translateX(10px);
        }

        /* Sections */
        section {
            min-height: 100vh;
            padding: 120px 5% 80px;
            max-width: 1200px;
            margin: 0 auto;
            opacity: 0;
            transform: translateY(50px);
            transition: all 0.8s ease;
        }

        section.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 6vw, 4rem);
            text-align: center;
            color: #8b1a4e;
            margin-bottom: 3rem;
            position: relative;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 3px;
            background: linear-gradient(45deg, #ff69b4, #ff1493);
        }

        /* About Him */
        .about-content {
            max-width: 800px;
            margin: 0 auto;
            text-align: center;
            font-size: 1.3rem;
            font-style: italic;
            color: #6b4e71;
        }

        /* Timeline */
        .timeline {
            position: relative;
            max-width: 800px;
            margin: 0 auto;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, #ff69b4, #ff1493);
            transform: translateX(-50%);
        }

        .timeline-item {
            position: relative;
            margin: 3rem 0;
            width: 45%;
            padding: 2rem;
            background: rgba(255,255,255,0.9);
            border-radius: 20px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
            backdrop-filter: blur(10px);
        }

        .timeline-item:nth-child(odd) {
            margin-left: 5%;
        }

        .timeline-item:nth-child(even) {
            margin-left: auto;
            margin-right: 5%;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            top: 30px;
            width: 20px;
            height: 20px;
            background: linear-gradient(45deg, #ff69b4, #ff1493);
            border-radius: 50%;
            z-index: 1;
        }

        .timeline-item:nth-child(odd)::before {
            right: -30px;
        }

        .timeline-item:nth-child(even)::before {
            left: -30px;
        }

        .timeline-icon {
            position: absolute;
            top: 20px;
            font-size: 1.5rem;
            color: #ff69b4;
        }

        /* Reasons List */
        .reasons-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            max-width: 1000px;
            margin: 0 auto;
        }

        .reason-item {
            background: rgba(255,255,255,0.9);
            padding: 2rem;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .reason-item:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 50px rgba(255,105,180,0.3);
        }

        .reason-number {
            font-size: 2rem;
            color: #ff69b4;
            font-weight: bold;
            margin-bottom: 1rem;
        }

        /* Messages */
        .messages-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
        }

        .message-card {
            background: linear-gradient(135deg, rgba(255,182,193,0.2), rgba(255,105,180,0.1));
            padding: 2.5rem;
            border-radius: 25px;
            text-align: center;
            border: 1px solid rgba(255,105,180,0.3);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .message-card:hover {
            transform: scale(1.05);
            box-shadow: 0 20px 50px rgba(255,105,180,0.4);
        }

        /* Gallery */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .gallery-item {
            position: relative;
            height: 300px;
            background: linear-gradient(45deg, #ff69b4, #ff1493);
            border-radius: 20px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .gallery-item:hover {
            transform: scale(1.05);
        }

        .gallery-placeholder {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: white;
            font-size: 1.5rem;
            font-weight: 600;
        }

        .gallery-caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 1rem;
            text-align: center;
        }

        /* Future */
        .future-content {
            max-width: 800px;
            margin: 0 auto;
            text-align: center;
            font-size: 1.2rem;
        }

        /* Surprise */
        .surprise-btn {
            display: block;
            margin: 4rem auto 0;
            background: linear-gradient(45deg, #ffd700, #ffed4e);
            color: #8b1a4e;
            border: none;
            padding: 1.5rem 3rem;
            font-size: 1.3rem;
            font-weight: 600;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(255,215,0,0.4);
        }

        .surprise-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(255,215,0,0.6);
        }

        .surprise-message {
            display: none;
            text-align: center;
            padding: 3rem;
            background: linear-gradient(135deg, #fff0f5, #ffe4e1);
            border-radius: 25px;
            margin-top: 2rem;
            border: 2px solid #ff69b4;
            animation: surprisePop 0.5s ease;
        }

        @keyframes surprisePop {
            0% { transform: scale(0.5); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        /* Smooth Scrolling */
        html {
            scroll-behavior: smooth;
        }

        /* Mobile Responsiveness */
        @media (max-width: 768px) {
            .timeline::before {
                left: 20px;
            }
            
            .timeline-item {
                width: calc(100% - 60px);
                margin-left: 60px !important;
                margin-right: 0 !important;
            }
            
            .timeline-item::before {
                left: -30px !important;
                right: auto !important;
            }
            
            .nav {
                top: 1rem;
                right: 1rem;
            }
        }

        /* Audio Player */
        .audio-player {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(255,255,255,0.95);
            padding: 1rem 2rem;
            border-radius: 50px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            backdrop-filter: blur(20px);
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .audio-player button {
            background: none;
            border: none;
            font-size: 1.5rem;
            color: #ff69b4;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .audio-player button:hover {
            transform: scale(1.2);
        }
    </style>
</head>
